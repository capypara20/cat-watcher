# Rust ビルド成果物
/target
/**/target

# 実行ファイル (バイナリはリポジトリに含めない)
/cat-watcher.exe
/rust-folder-watcher
/dist/
/bin/

# ローカル設定 (リポジトリ直下に置く個別の動作用設定)
# サンプル設定は config/ にコミット済みのものを使う
/global.toml
/rules.toml

# 動作時のログ
/log/

# テスト用フォルダ
/watch-test/

# 旧仕様の残骸
/data/

# toolも
/tool/*

# OS / エディタ
.DS_Store
*.swp
*.swo

# Claude Code のローカル設定 (個人ごとの設定なので一切コミットしない)
/.claude/
